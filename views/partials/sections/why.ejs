<!-- ==================== Why Section ==================== -->
<section class="why" id="why">

  <!-- Hook -->
  <div class="why__hook">
    <div class="container">
      <div class="why__hook-inner reveal">
        <h2 class="why__headline">
          Menschen bilden sich ein Urteil –
          <em>bevor sie mit Ihnen sprechen.</em>
        </h2>
      </div>
    </div>
  </div>

  <!-- Stats: 3 animated SVG cards -->
  <div class="why__stats-wrap">
    <div class="container">
      <div class="why__stats reveal" data-delay="1">

        <!-- Card 1: 75 % Donut Chart -->
        <div class="why__stat-card">
          <div class="why__stat-svg-wrap">
            <svg class="why__stat-svg" viewBox="0 0 120 120" aria-hidden="true">
              <defs>
                <linearGradient id="donutGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#2563EB"/>
                  <stop offset="100%" stop-color="#7c3aed"/>
                </linearGradient>
              </defs>
              <circle class="why__donut-track" cx="60" cy="60" r="44" fill="none" stroke-width="10"/>
              <circle class="why__donut-fill" cx="60" cy="60" r="44"
                fill="none" stroke="url(#donutGrad)" stroke-width="10"
                stroke-linecap="round" transform="rotate(-90 60 60)"/>
              <text class="why__svg-center" x="60" y="66" text-anchor="middle">75 %</text>
            </svg>
          </div>
          <span class="why__stat-label">Urteilen, bevor sie anrufen</span>
          <p class="why__stat-desc"><strong>Drei von vier Kunden</strong> haben ihre Meinung über Sie längst gebildet, bevor sie anrufen. Was diese Meinung geformt hat, ist allein <strong>Ihre Website</strong>.</p>
        </div>

        <!-- Card 2: 24/7 Clock -->
        <div class="why__stat-card why__stat-card--clock">
          <div class="why__stat-svg-wrap">
            <svg class="why__stat-svg" viewBox="5 5 110 110" aria-hidden="true">
              <circle class="why__clock-face" cx="60" cy="60" r="44" fill="none" stroke-width="2"/>
              <text class="why__clock-num" x="60" y="34" text-anchor="middle">12</text>
              <text class="why__clock-num" x="91" y="64" text-anchor="middle">3</text>
              <text class="why__clock-num" x="60" y="95" text-anchor="middle">6</text>
              <text class="why__clock-num" x="29" y="64" text-anchor="middle">9</text>
              <line class="why__clock-hour"   x1="60" y1="60" x2="60" y2="38" stroke-linecap="round"/>
              <line class="why__clock-minute" x1="60" y1="60" x2="60" y2="24" stroke-linecap="round"/>
              <circle class="why__clock-center" cx="60" cy="60" r="3"/>
            </svg>
          </div>
          <span class="why__stat-label">Rund um die Uhr erreichbar</span>
          <p class="why__stat-desc">Irgendwer sucht gerade nach dem, was Sie anbieten. <strong>Gestern Abend, am Wochenende, in der Mittagspause</strong> – und wenn Ihre Seite dabei nicht überzeugt, ruft er morgen <strong>jemand anderen</strong> an.</p>
        </div>

        <!-- Card 3: Hourglass -->
        <div class="why__stat-card why__stat-card--hourglass">
          <div class="why__stat-svg-wrap">
            <div class="why__hg-wrap">
            <svg class="why__stat-svg" viewBox="-64 -64 640 640" aria-hidden="true">
              <defs>
                <linearGradient id="hgGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#7c3aed"/>
                  <stop offset="100%" stop-color="#2563EB"/>
                </linearGradient>
                <linearGradient id="hgStreamGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#2563EB"/>
                  <stop offset="100%" stop-color="#7c3aed"/>
                </linearGradient>
                <clipPath id="hgClipTop">
                  <path d="
                    M 128,64
                    C 128,64  128,176  198,234
                    C 214,245  224,249  230,250
                    L 282,250
                    C 288,249  298,245  314,234
                    C 384,176  384,64   384,64
                    Z
                  "/>
                </clipPath>
                <clipPath id="hgClipBot">
                  <path d="
                    M 128,448
                    C 128,448  128,336  198,278
                    C 214,267  224,263  230,262
                    L 282,262
                    C 288,263  298,267  314,278
                    C 384,336  384,448  384,448
                    Z
                  "/>
                </clipPath>
              </defs>
              <!-- Upper sand -->
              <g clip-path="url(#hgClipTop)">
                <rect id="hgSandTop" x="80" y="64" width="352" height="186" fill="url(#hgGrad)"/>
              </g>
              <!-- Lower sand -->
              <g clip-path="url(#hgClipBot)">
                <rect id="hgSandBot" x="80" y="448" width="352" height="0" fill="url(#hgGrad)"/>
              </g>
              <!-- Sand stream -->
              <rect id="hgStream" fill="url(#hgStreamGrad)" opacity="0"
                    x="242" y="249.2" width="28" height="2.8"/>
              <!-- Frame: durchgehende Kurven links + rechts -->
              <g class="why__hg-frame-group">
                <line x1="96"  y1="64"  x2="416" y2="64"/>
                <line x1="96"  y1="448" x2="416" y2="448"/>
                <path d="M 128,64 C 128,64 128,176 198,234 C 214,247 224,248 228,256 C 224,264 214,265 198,278 C 128,336 128,448 128,448"/>
                <path d="M 384,64 C 384,64 384,176 314,234 C 298,247 288,248 284,256 C 288,264 298,265 314,278 C 384,336 384,448 384,448"/>
              </g>
            </svg>
            </div>
          </div>
          <span class="why__stat-label">Der erste Eindruck</span>
          <p class="why__stat-desc">Besucher brauchen <strong>ein paar Sekunden</strong>, um zu entscheiden, ob sie bleiben. Kein Mensch liest dabei Ihr Angebot – er schaut die Seite an und weiß es einfach. <strong>Diesen Moment zurückzudrehen gibt es nicht.</strong></p>
        </div>

      </div>
    </div>
  </div>

